{
  "name": "aura-node-studio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "validate:contracts": "npm --prefix packages/contracts run validate:examples",
    "import:fritzing-library": "node ./scripts/import_fritzing_library.mjs",
    "sync:kicad-library": "node ./scripts/sync_kicad_symbol_index.mjs",
    "dev:web": "npm --prefix apps/studio_web run dev",
    "build:web": "npm --prefix apps/studio_web run build",
    "dev:api": "npm --prefix apps/studio_api run dev",
    "start:api": "npm --prefix apps/studio_api run start"
  }
}
