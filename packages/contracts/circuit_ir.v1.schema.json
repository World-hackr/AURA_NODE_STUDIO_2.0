{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aura/contracts/circuit_ir.v1",
  "title": "AURA Circuit IR V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "metadata", "components", "nets"],
  "properties": {
    "schema": {
      "const": "aura.circuit_ir.v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "sourceIntentId": { "type": "string" },
        "viewMode": {
          "type": "string",
          "enum": ["breadboard", "schematic", "mixed"]
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "packageId", "reference", "placement"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "packageId": { "type": "string", "minLength": 1 },
          "reference": { "type": "string", "minLength": 1 },
          "attrs": {
            "type": "object",
            "additionalProperties": true
          },
          "runtimeProfileId": { "type": "string" },
          "placement": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "rotationDeg"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "rotationDeg": { "type": "number" }
            }
          }
        }
      }
    },
    "nets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "connections"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "connections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["componentId", "pinId"],
              "properties": {
                "componentId": { "type": "string" },
                "pinId": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "text"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["note", "warning", "label"]
          },
          "text": { "type": "string" }
        }
      }
    }
  }
}
