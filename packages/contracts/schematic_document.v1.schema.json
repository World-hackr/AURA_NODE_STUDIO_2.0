{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aura/contracts/schematic_document.v1",
  "title": "AURA Schematic Document V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "metadata", "instances", "nets"],
  "properties": {
    "schema": {
      "const": "aura.schematic_document.v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "sourceIntentId": { "type": "string" },
        "standard": {
          "type": "string",
          "enum": ["iec", "ansi", "mixed"]
        }
      }
    },
    "instances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "symbolKey", "reference", "placement"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "symbolKey": { "type": "string", "minLength": 1 },
          "reference": { "type": "string", "minLength": 1 },
          "value": { "type": "string" },
          "unitId": { "type": "string" },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "placement": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "rotationDeg"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "rotationDeg": { "type": "number" },
              "mirrorX": { "type": "boolean" },
              "mirrorY": { "type": "boolean" }
            }
          }
        }
      }
    },
    "nets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "connections"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "connections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["instanceId", "pinId"],
              "properties": {
                "instanceId": { "type": "string", "minLength": 1 },
                "pinId": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "x", "y"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    }
  }
}
