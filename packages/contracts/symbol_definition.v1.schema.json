{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aura/contracts/symbol_definition.v1",
  "title": "AURA Symbol Definition V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "metadata", "body", "pins"],
  "properties": {
    "schema": {
      "const": "aura.symbol_definition.v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "name", "sourceKind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sourceKind": {
          "type": "string",
          "enum": ["kicad", "easyeda", "manual", "native"]
        },
        "sourceLibrary": { "type": "string" },
        "sourceSymbol": { "type": "string" },
        "defaultReferencePrefix": { "type": "string", "minLength": 1 },
        "symbolKey": { "type": "string", "minLength": 1 }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "pinLayout"],
      "properties": {
        "shape": {
          "type": "string",
          "enum": ["rectangle", "circle", "diamond", "opamp", "custom"]
        },
        "pinLayout": {
          "type": "string",
          "enum": ["single_side", "opposite_sides", "four_side", "split_units", "custom"]
        },
        "units": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        },
        "graphics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["rectangle", "polyline", "circle", "arc", "text"]
              },
              "unitId": { "type": "string" },
              "x1": { "type": "number" },
              "y1": { "type": "number" },
              "x2": { "type": "number" },
              "y2": { "type": "number" },
              "cx": { "type": "number" },
              "cy": { "type": "number" },
              "radius": { "type": "number" },
              "points": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["x", "y"],
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" }
                  }
                }
              },
              "text": { "type": "string" },
              "fontSize": { "type": "number" },
              "rotationDeg": { "type": "number" },
              "strokeWidth": { "type": "number" },
              "strokeType": { "type": "string" },
              "fillType": { "type": "string" }
            }
          }
        }
      }
    },
    "pins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "number", "name", "side", "electricalType"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "number": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "side": {
            "type": "string",
            "enum": ["top", "right", "bottom", "left", "hidden"]
          },
          "electricalType": {
            "type": "string",
            "enum": [
              "input",
              "output",
              "bidirectional",
              "tri_state",
              "passive",
              "power_in",
              "power_out",
              "open_collector",
              "open_emitter",
              "no_connect",
              "unspecified"
            ]
          },
          "unitId": { "type": "string" },
          "graphicalStyle": {
            "type": "string",
            "enum": ["line", "clock", "inverted", "clock_inverted", "input_low", "output_low", "non_logic"]
          },
          "sequence": { "type": "integer", "minimum": 0 },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "innerX": { "type": "number" },
          "innerY": { "type": "number" },
          "length": { "type": "number" },
          "angleDeg": { "type": "number" }
        }
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "value"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "value": { "type": "string" },
          "visible": { "type": "boolean" }
        }
      }
    }
  }
}
