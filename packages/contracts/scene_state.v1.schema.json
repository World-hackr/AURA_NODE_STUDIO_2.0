{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aura/contracts/scene_state.v1",
  "title": "AURA Scene State V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "metadata", "canvas", "components", "wires", "junctions", "selection", "netSummary"],
  "properties": {
    "schema": {
      "const": "aura.scene_state.v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "captureSource"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "captureSource": {
          "type": "string",
          "enum": ["studio_canvas", "selection_export", "preview_overlay"]
        },
        "sourceSchematicId": { "type": "string" },
        "sourceRevision": { "type": "integer", "minimum": 0 },
        "standard": {
          "type": "string",
          "enum": ["iec", "ansi", "mixed"]
        }
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grid", "viewport"],
      "properties": {
        "grid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["unitMm", "pixelsPerUnit"],
          "properties": {
            "unitMm": { "type": "number", "exclusiveMinimum": 0 },
            "pixelsPerUnit": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "viewport": {
          "type": "object",
          "additionalProperties": false,
          "required": ["zoom", "offsetX", "offsetY"],
          "properties": {
            "zoom": { "type": "number", "exclusiveMinimum": 0 },
            "offsetX": { "type": "number" },
            "offsetY": { "type": "number" }
          }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "symbolKey", "reference", "placement", "bodyBounds", "pins"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "symbolKey": { "type": "string", "minLength": 1 },
          "reference": { "type": "string", "minLength": 1 },
          "value": { "type": "string" },
          "unitId": { "type": "string" },
          "fields": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "boolean", "null"]
            }
          },
          "placement": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "rotationDeg"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "rotationDeg": { "type": "number" },
              "mirrorX": { "type": "boolean" },
              "mirrorY": { "type": "boolean" }
            }
          },
          "bodyBounds": {
            "type": "object",
            "additionalProperties": false,
            "required": ["left", "top", "right", "bottom"],
            "properties": {
              "left": { "type": "number" },
              "top": { "type": "number" },
              "right": { "type": "number" },
              "bottom": { "type": "number" }
            }
          },
          "pins": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pinId", "x", "y"],
              "properties": {
                "pinId": { "type": "string", "minLength": 1 },
                "number": { "type": "string" },
                "name": { "type": "string" },
                "electricalType": { "type": "string" },
                "direction": {
                  "type": "string",
                  "enum": ["left", "right", "up", "down"]
                },
                "x": { "type": "number" },
                "y": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "wires": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "routePoints"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "netId": { "type": "string" },
          "label": { "type": "string" },
          "from": {
            "$ref": "#/$defs/wireEndpoint"
          },
          "to": {
            "$ref": "#/$defs/wireEndpoint"
          },
          "routePoints": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/point"
            }
          }
        }
      }
    },
    "junctions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "x", "y"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["componentIds", "wireIds", "junctionIds", "scope"],
      "properties": {
        "componentIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wireIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "junctionIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scope": {
          "type": "string",
          "enum": ["parts", "wires", "both"]
        }
      }
    },
    "netSummary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "members"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "id"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["component_pin", "wire", "junction"]
                },
                "id": { "type": "string", "minLength": 1 },
                "pinId": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "message"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error"]
          },
          "message": { "type": "string", "minLength": 1 },
          "relatedIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "wireEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["pin", "junction"]
        },
        "componentId": { "type": "string", "minLength": 1 },
        "pinId": { "type": "string", "minLength": 1 },
        "junctionId": { "type": "string", "minLength": 1 }
      },
      "oneOf": [
        {
          "required": ["kind", "componentId", "pinId"],
          "properties": {
            "kind": { "const": "pin" },
            "componentId": { "type": "string", "minLength": 1 },
            "pinId": { "type": "string", "minLength": 1 }
          }
        },
        {
          "required": ["kind", "junctionId"],
          "properties": {
            "kind": { "const": "junction" },
            "junctionId": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
