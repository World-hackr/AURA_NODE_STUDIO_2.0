{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aura/contracts/circuit_intent.v1",
  "title": "AURA Circuit Intent V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "metadata", "requirements"],
  "properties": {
    "schema": {
      "const": "aura.circuit_intent.v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "userPrompt"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "userPrompt": { "type": "string", "minLength": 1 },
        "preferredView": {
          "type": "string",
          "enum": ["breadboard", "schematic", "mixed"]
        },
        "createdBy": { "type": "string" }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parts"],
      "properties": {
        "goal": { "type": "string" },
        "parts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "query", "quantity"],
            "properties": {
              "role": { "type": "string", "minLength": 1 },
              "query": { "type": "string", "minLength": 1 },
              "quantity": { "type": "integer", "minimum": 1 },
              "valueHint": { "type": "string" },
              "packageHint": { "type": "string" },
              "required": { "type": "boolean", "default": true },
              "notes": { "type": "string" }
            }
          }
        },
        "connections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fromRole", "toRole"],
            "properties": {
              "fromRole": { "type": "string" },
              "fromPinHint": { "type": "string" },
              "toRole": { "type": "string" },
              "toPinHint": { "type": "string" },
              "netLabel": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxPartCount": { "type": "integer", "minimum": 1 },
            "allowSubstitutions": { "type": "boolean" },
            "prioritizeSimplicity": { "type": "boolean" },
            "preferBoards": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "reviewHints": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
